{
  "expo": {
    "name": "Bean — Travel App",
    "slug": "bean-travel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bean-travel",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF9F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.beantravel.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Bean uses your microphone to transcribe your spoken words into notes.",
        "NSSpeechRecognitionUsageDescription": "Bean uses speech recognition to convert your voice into text for notes and descriptions.",
        "NSCameraUsageDescription": "Bean uses your camera to capture photos for your travel memories.",
        "NSPhotoLibraryUsageDescription": "Bean accesses your photo library so you can attach travel photos to your places.",
        "NSPhotoLibraryAddUsageDescription": "Bean saves your travel memory photos to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Bean uses your location to show where you are on your travel map.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF9F4"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.beantravel.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-av",
      "./plugins/withModularHeaders"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "64350cdb-44b4-4683-812d-b199198dd0bb"
      }
    }
  }
}
