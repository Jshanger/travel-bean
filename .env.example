DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE
PORT=3000

# Public domain without https://, for example travelbean.app or your-replit-name.replit.app.
EXPO_PUBLIC_DOMAIN=travelbean.app

# Clerk auth, required for signed-in app actions.
CLERK_PUBLISHABLE_KEY=pk_test_or_live_...
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_...
EXPO_PUBLIC_CLERK_PROXY_URL=https://travelbean.app/api/__clerk

# RevenueCat keys, if premium features are enabled in this deployment.
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# Optional. Defaults to bean-travel/dist when omitted.
WEB_DIST_DIR=

# Cloudflare R2 photo storage. Keep the bucket private; the API exposes only
# photos attached to published public blog posts.
R2_ACCOUNT_ID=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=travel-bean-photos
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
